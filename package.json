{
  "name": "gravitycargo-testing",
  "version": "1.0.0",
  "description": "Playwright testing for GravityCARgo container optimization",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:volume": "playwright test tests/playwright/container-optimization.spec.ts -g \"volume\"",
    "install:playwright": "npx playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "playwright",
    "testing",
    "container",
    "optimization",
    "volume",
    "ar"
  ],
  "author": "GravityCARgo Team",
  "license": "ISC"
}
